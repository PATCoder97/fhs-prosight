{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host", "127.0.0.1",
                "--port", "8001"
            ],
            "jinja": true,
            "justMyCode": true,
            // THÊM DÒNG DƯỚI ĐÂY:
            "cwd": "${workspaceFolder}/fhs-prosight/backend", 
            "env": {
                "PYTHONPATH": "${workspaceFolder}/fhs-prosight/backend"
            }
        }
    ]
}